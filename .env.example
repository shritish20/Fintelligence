# ═══════════════════════════════════════════════════════════════════════════════
# FINTELLIGENCE — Environment Variables (SaaS Edition)
# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── DATABASE (PostgreSQL) ─────────────────────────────────────────────────────
# Multi-tenant PostgreSQL — all 4 backends share one DB, isolated by user_id
POSTGRES_USER=fintelligence
POSTGRES_PASSWORD=change_this_strong_password_here
POSTGRES_DB=fintelligence
# DATABASE_URL is auto-constructed in docker-compose from the vars above.
# If running backends outside Docker, set this manually:
# DATABASE_URL=postgresql://fintelligence:yourpassword@localhost:5432/fintelligence

# ── CACHE (Redis) ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password_here
# REDIS_URL is auto-constructed in docker-compose. For manual use:
# REDIS_URL=redis://:yourpassword@localhost:6379/0

# ── UPSTOX API ────────────────────────────────────────────────────────────────
# Analytics Token — generates once from Upstox Developer Portal → Analytics tab
# Valid for 1 year. Read-only: market quotes, option chain, WebSocket, Greeks.
# Powers the intelligence layer for all users without daily action.
UPSTOX_ANALYTICS_TOKEN=your_analytics_token_here

# Daily OAuth token — NOT stored here.
# Option B: broker token lives ONLY on the user's device (sessionStorage).
# It is never sent to or stored on the server. Users paste it via the UI each morning.
# This is your competitive moat — "your broker token never leaves your phone."

# ── AI PROVIDERS ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# ── VOLGUARD SPECIFIC ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── SECURITY ──────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_another_long_random_string
# JWT secret — signs all user session tokens across all backends
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_64_char_random_hex_string_minimum_32_chars

# ── SUBSCRIPTIONS (Razorpay) ──────────────────────────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_your_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# Webhook secret for verifying payment callbacks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── USER LIMITS ───────────────────────────────────────────────────────────────
# Max registered users (for private beta; remove or raise for public launch)
MAX_USERS=200

# ── OPTIONAL: FRED API (US macro data) ───────────────────────────────────────
FRED_API_KEY=your_fred_api_key

# ── NOTES ─────────────────────────────────────────────────────────────────────
# TOKEN_ENCRYPTION_KEY removed — broker tokens no longer stored server-side (Option B).
# VOLGUARD_SECRET removed — all session signing uses JWT_SECRET.
